---
// Standards index page
import BaseLayout from '../../layouts/BaseLayout.astro';
import SectionHeader from '../../components/ui/SectionHeader.astro';
import StandardCard from '../../components/cards/StandardCard.astro';
import { standards } from '../../data/standards';
---

<BaseLayout
  title="Browse Standards"
  description={`Reference pages for ${standards.length} e-invoice formats and standards including EN 16931, Peppol BIS 3, XRechnung, and Factur-X. Understand technical requirements and interoperability.`}
>
  <div class="container-content page-standards">
    <div class="page-hero">
      <h1 class="page-h1">Format & Standard Reference</h1>
      <SectionHeader
        eyebrow="By Standard"
        title="Understand 6 e-invoice formats and standards used globally. Each reference page covers specification details, mandatory fields, country coverage, and implementation notes."
      />
    </div>

    <div class="standards-grid">
      {standards.map(std => (
        <StandardCard
          slug={std.urlSlug ?? std.slug}
          name={std.shortName}
          shortName={std.shortName}
          category={std.category}
          governingBody={std.governingBody}
          countriesUsing={std.countriesUsing}
          isPeppolBased={std.isPeppolBased}
        />
      ))}
    </div>
  </div>
</BaseLayout>

<style>
  .page-standards {
    padding: var(--space-12) 0 var(--space-20);
  }

  .page-hero {
    margin-bottom: var(--space-12);
  }

  .page-h1 {
    font-size: var(--text-3xl);
    font-weight: 800;
    color: var(--color-slate-950);
    margin: 0 0 var(--space-3);
    letter-spacing: var(--tracking-tight);
  }

  .standards-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-4);
  }

  @media (max-width: 1024px) {
    .standards-grid { grid-template-columns: repeat(2, 1fr); }
  }

  @media (max-width: 640px) {
    .standards-grid { grid-template-columns: 1fr; }
  }
</style>
