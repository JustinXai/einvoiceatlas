---
// Homepage — EInvoiceAtlas main landing page
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/blocks/Hero.astro';
import SectionHeader from '../components/ui/SectionHeader.astro';
import DeadlineBanner from '../components/blocks/DeadlineBanner.astro';
import CountryCard from '../components/cards/CountryCard.astro';
import StandardCard from '../components/cards/StandardCard.astro';
import ERPCard from '../components/cards/ERPCard.astro';
import HookCard from '../components/cards/HookCard.astro';
import DisclaimerBox from '../components/ui/DisclaimerBox.astro';
import { countries, getUpcomingCountries, getActiveMandateCountries } from '../data/countries';
import { standards } from '../data/standards';
import { erpSystems } from '../data/erpSystems';

const upcomingCountries = getUpcomingCountries();
const activeCountries = getActiveMandateCountries();
const featuredCountries = [...activeCountries.slice(0, 3), ...upcomingCountries.slice(0, 3)].slice(0, 6);
const featuredStandards = standards.filter((standard) => ['zugferd', 'xrechnung', 'en-16931', 'factur-x', 'peppol-bis-3'].includes(standard.slug));
---

<BaseLayout
  title={undefined}
  description="Navigate mandatory e-invoicing requirements by country, standard, and ERP system. Independent regulatory intelligence for finance, tax, and compliance teams."
>
  <div class="homepage">
    <section class="section-hero">
      <div class="container-content">
        <Hero variant="homepage" />
      </div>
    </section>

    <section class="section-standards-nav">
      <div class="container-content">
        <SectionHeader
          eyebrow="Standards"
          title="Standards and formats to understand first"
          description="A concise navigation block for teams comparing invoice formats, semantic models, and routing paths."
          size="sm"
        />
        <div class="standards-nav-grid">
          <a href="/standards/zugferd/" class="standards-nav-card">
            <strong>ZUGFeRD</strong>
            <span>Hybrid PDF/XML invoice family</span>
          </a>
          <a href="/standards/xrechnung/" class="standards-nav-card">
            <strong>XRechnung</strong>
            <span>German XML format reference</span>
          </a>
          <a href="/standards/en-16931/" class="standards-nav-card">
            <strong>EN 16931 / EN16931</strong>
            <span>Semantic invoice model</span>
          </a>
          <a href="/standards/factur-x/" class="standards-nav-card">
            <strong>Factur-X</strong>
            <span>French hybrid invoice family</span>
          </a>
          <a href="/standards/peppol-bis-3/" class="standards-nav-card">
            <strong>Peppol BIS 3.0</strong>
            <span>Peppol invoice specification</span>
          </a>
          <a href="/routes/peppol-access-point/" class="standards-nav-card">
            <strong>Peppol Access Point</strong>
            <span>Routing and provider selection</span>
          </a>
        </div>
      </div>
    </section>

    {upcomingCountries.length > 0 && (
      <section class="section-upcoming">
        <div class="container-content">
          <div class="upcoming-header">
            <SectionHeader
              eyebrow="Watch List"
              title="Upcoming Mandates"
              description="Deadlines approaching. These mandates are in effect or becoming mandatory soon."
              size="sm"
            />
            <a href="/countries?status=upcoming" class="view-all-link">
              View all upcoming
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                <line x1="5" y1="12" x2="19" y2="12"/>
                <polyline points="12 5 19 12 12 19"/>
              </svg>
            </a>
          </div>
          <div class="upcoming-banners">
            {upcomingCountries.slice(0, 3).map(country => (
              <DeadlineBanner
                country={country.name}
                date={country.effectiveDate ?? ''}
                phase={country.mandatePhase}
                slug={country.urlSlug ?? country.slug}
                urgency={country.enforcementDate && new Date(country.enforcementDate) < new Date('2027-01-01') ? 'high' : 'medium'}
              />
            ))}
          </div>
        </div>
      </section>
    )}

    <section class="section-countries">
      <div class="container-content">
        <div class="section-header-row">
          <SectionHeader
            eyebrow="By Country"
            title="Explore Country Mandates"
            description="Select a country to see its e-invoicing mandate, required formats, ERP impact, and implementation checklist."
          />
        </div>
        <div class="country-grid">
          {featuredCountries.map(country => (
            <CountryCard
              slug={country.slug}
              name={country.name}
              isoCode={country.isoCode}
              status={country.status}
              effectiveDate={country.effectiveDate}
              mandatePhase={country.mandatePhase}
              formats={country.formats}
            />
          ))}
        </div>
        <div class="section-cta"><a href="/countries" class="browse-all-btn">Browse All Countries</a></div>
      </div>
    </section>

    <section class="section-standards">
      <div class="container-content">
        <div class="section-header-row">
          <SectionHeader
            eyebrow="By Standard"
            title="Format & Standard Reference"
            description="Understand EN 16931, Peppol BIS 3, XRechnung, Factur-X, and other formats used globally."
          />
        </div>
        <div class="standards-grid">
          {featuredStandards.map(std => (
            <StandardCard
              slug={std.slug}
              name={std.name}
              shortName={std.shortName}
              category={std.category}
              governingBody={std.governingBody}
              countriesUsing={std.countriesUsing}
              isPeppolBased={std.isPeppolBased}
              compact={true}
            />
          ))}
        </div>
        <div class="section-cta"><a href="/standards" class="browse-all-btn secondary">Browse All Standards</a></div>
      </div>
    </section>

    <section class="section-erp">
      <div class="container-content">
        <div class="section-header-row">
          <SectionHeader
            eyebrow="By ERP"
            title="Accounting System Impact"
            description="Find out how your ERP or accounting system supports mandatory e-invoicing formats."
          />
        </div>
        <div class="erp-grid">
          {erpSystems.slice(0, 6).map(erp => (
            <ERPCard
              slug={erp.slug}
              name={erp.name}
              vendor={erp.vendor}
              category={erp.category}
              nativeEInvoiceSupport={erp.nativeEInvoiceSupport}
              applicableCountries={erp.applicableCountries}
              configurationComplexity={erp.configurationComplexity}
            />
          ))}
        </div>
        <div class="section-cta"><a href="/erp" class="browse-all-btn secondary">Browse All ERP Systems</a></div>
      </div>
    </section>

    <section class="section-hooks">
      <div class="container-content">
        <SectionHeader
          eyebrow="Free Resources"
          title="Plan Your E-Invoicing Implementation"
          description="Get structured assessments, roadmaps, and comparison briefs to guide your compliance journey."
          align="center"
        />
        <div class="hooks-grid">
          <HookCard name="Country Readiness Checklist" description="Get a structured 10-point readiness assessment for your target country's mandate." ctaLabel="Get Country Checklist" icon="checklist" href="/countries" />
          <HookCard name="Provider Shortlist Request" description="Get matched with vetted e-invoicing providers based on your country, ERP, and route." ctaLabel="Request Shortlist" icon="shortlist" href="/routes" />
          <HookCard name="Standard Comparison Brief" description="Side-by-side comparison of EN 16931, Peppol BIS 3, XRechnung, Factur-X, and more." ctaLabel="Download Comparison" icon="comparison" href="/standards" />
          <HookCard name="Find Your E-Invoicing Route" description="Answer 4 questions to determine whether to use Peppol, API, Portal, or Hybrid route." ctaLabel="Take Decision Aid" icon="route" href="/routes" />
        </div>
      </div>
    </section>

    <section class="section-guide">
      <div class="container-content">
        <div class="guide-card">
          <SectionHeader eyebrow="Getting Started" title="How to Use This Site" size="md" />
          <div class="guide-paths">
            <div class="guide-path">
              <h3>Start by Country</h3>
              <p>Know which country you need to comply with? Go directly to the country dossier for mandate dates, formats, and implementation steps.</p>
              <a href="/countries">Browse Countries →</a>
            </div>
            <div class="guide-path">
              <h3>Start by Standard</h3>
              <p>Need to understand a specific format? The standard reference pages explain EN 16931, Peppol, XRechnung, and more.</p>
              <a href="/standards">Browse Standards →</a>
            </div>
            <div class="guide-path">
              <h3>Start by ERP</h3>
              <p>Working inside an ERP or accounting system? See how your platform handles e-invoice export and validation.</p>
              <a href="/erp">Browse ERP Systems →</a>
            </div>
          </div>
        </div>
      </div>
    </section>

    <DisclaimerBox />
  </div>
</BaseLayout>

<style>
  .homepage { display: flex; flex-direction: column; gap: var(--space-12); }
  .section-standards-nav { padding-top: var(--space-4); }
  .standards-nav-grid { display: grid; grid-template-columns: repeat(3, minmax(0, 1fr)); gap: var(--space-4); }
  .standards-nav-card { display: flex; flex-direction: column; gap: var(--space-1); padding: var(--space-4); border: 1px solid var(--color-border); border-radius: var(--radius-lg); background: var(--color-surface); color: inherit; text-decoration: none; }
  .standards-nav-card strong { font-size: var(--text-sm); }
  .standards-nav-card span { font-size: var(--text-xs); color: var(--color-slate-600); }
  .guide-paths { display: grid; grid-template-columns: repeat(3, minmax(0, 1fr)); gap: var(--space-4); }
</style>
