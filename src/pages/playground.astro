---
// Playground — EInvoiceAtlas User Journey Visualization
// This page demonstrates how real users navigate from entry to conversion.
// Every section shows: WHY here → WHAT they learn → WHAT next.
// Flow connections between blocks are explicitly visualized.
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/blocks/Hero.astro';
import SectionHeader from '../components/ui/SectionHeader.astro';
import StatusBadge from '../components/ui/StatusBadge.astro';
import AISummaryBox from '../components/ui/AISummaryBox.astro';
import QuickAnswerBox from '../components/ui/QuickAnswerBox.astro';
import InfoBlock from '../components/ui/InfoBlock.astro';
import DisclaimerBox from '../components/ui/DisclaimerBox.astro';
import SourcesBox from '../components/ui/SourcesBox.astro';
import Breadcrumb from '../components/ui/Breadcrumb.astro';
import CountryCard from '../components/cards/CountryCard.astro';
import StandardCard from '../components/cards/StandardCard.astro';
import ERPCard from '../components/cards/ERPCard.astro';
import HookCard from '../components/cards/HookCard.astro';
import ImplementationChecklist from '../components/blocks/ImplementationChecklist.astro';
import DeadlineBanner from '../components/blocks/DeadlineBanner.astro';
import ProviderRouteBox from '../components/blocks/ProviderRouteBox.astro';
import ShortlistForm from '../components/forms/ShortlistForm.astro';
import { countries } from '../data/countries';
import { standards } from '../data/standards';
import { erpSystems } from '../data/erpSystems';
import { providerRoutes } from '../data/providers';
import { contentHooks } from '../data/contentHooks';
import { userJourneys } from '../data/userJourneys';

// Sample data
const france = countries.find(c => c.slug === 'france')!;
const germany = countries.find(c => c.slug === 'germany')!;
const belgium = countries.find(c => c.slug === 'belgium')!;
const en16931 = standards.find(s => s.slug === 'en-16931')!;
const peppolBis = standards.find(s => s.slug === 'peppol-bis-3')!;
const facturx = standards.find(s => s.slug === 'factur-x')!;
const xrechnung = standards.find(s => s.slug === 'xrechnung')!;
const sap = erpSystems.find(e => e.slug === 'sap')!;
const odood = erpSystems.find(e => e.slug === 'odoo')!;
const peppolRoute = providerRoutes.find(r => r.slug === 'peppol-network')!;
const directApiRoute = providerRoutes.find(r => r.slug === 'direct-api')!;
const clearingHouseRoute = providerRoutes.find(r => r.slug === 'clearing-house')!;
const hybridRoute = providerRoutes.find(r => r.slug === 'hybrid')!;

// Active countries for grids
const activeMandateCountries = countries.filter(c =>
  c.status === 'mandatory' || c.status === 'active'
);

// Journey annotations for this playground
const journeyAnnotations = {
  'path-a-country-regulation': {
    annotationLabel: 'Journey A — Country Regulation Entry',
    annotationColor: 'accent',
    searchQuery: '"France e-invoicing mandate 2026"',
    entryPage: '/countries/france',
  },
  'path-b-standard-understanding': {
    annotationLabel: 'Journey B — Standard Understanding Entry',
    annotationColor: 'teal',
    searchQuery: '"Peppol BIS 3 explained"',
    entryPage: '/standards/peppol-bis-3',
  },
  'path-c-erp-implementation': {
    annotationLabel: 'Journey C — ERP Implementation Entry',
    annotationColor: 'amber',
    searchQuery: '"SAP e-invoicing Germany"',
    entryPage: '/erp/sap',
  },
  'path-d-purchase-intent': {
    annotationLabel: 'Journey D — Route Decision Entry',
    annotationColor: 'indigo',
    searchQuery: '"e-invoicing provider Belgium"',
    entryPage: '/routes',
  },
  'path-e-time-pressured': {
    annotationLabel: 'Journey E — Time-Pressured Entry',
    annotationColor: 'rose',
    searchQuery: '"Belgium mandate deadline 2026"',
    entryPage: '/countries/belgium',
  },
};
---

<BaseLayout title="User Journey Playground — EInvoiceAtlas" description="Visual walkthrough of EInvoiceAtlas user journeys from search entry to conversion.">

<div class="playground-page">

  <!-- ============================================================ -->
  <!-- PLAYGROUND HEADER — Journey Map Overview -->
  <!-- ============================================================ -->
  <div class="playground-banner">
    <div class="container-site">
      <div class="banner-inner">
        <div class="banner-label">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <circle cx="12" cy="12" r="10"/>
            <polyline points="12 6 12 12 16 14"/>
          </svg>
          <span>User Journey Playground</span>
        </div>
        <p class="banner-desc">
          This page visualizes how real users navigate EInvoiceAtlas — from search entry
          to conversion. Each section shows: <strong>why they're here</strong>,
          <strong>what they learn</strong>, and <strong>what they click next</strong>.
        </p>
        <div class="journey-legend">
          {Object.entries(journeyAnnotations).map(([id, ann]) => (
            <div class="legend-item">
              <span class={`legend-dot legend-${ann.annotationColor}`}></span>
              <span class="legend-label">{ann.annotationLabel}</span>
            </div>
          ))}
        </div>
      </div>
    </div>
  </div>

  <!-- ============================================================ -->
  <!-- JOURNEY A: Country Regulation Entry -->
  <!-- ============================================================ -->
  <section class="journey-section" id="journey-a" data-journey="path-a-country-regulation">
    <div class="container-site">

      <!-- Journey Header -->
      <div class="journey-header">
        <div class="journey-tag accent">
          <span class="journey-tag-dot"></span>
          Journey A
        </div>
        <div class="journey-meta">
          <div class="journey-search">
            <span class="search-icon">
              <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg>
            </span>
            <code>{journeyAnnotations['path-a-country-regulation'].searchQuery}</code>
          </div>
          <span class="entry-page">{journeyAnnotations['path-a-country-regulation'].entryPage}</span>
        </div>
        <h2 class="journey-title">Country Regulation Entry</h2>
        <p class="journey-persona">CFO · Finance Lead · Tax Manager</p>
        <p class="journey-desc">
          User found a country-specific page that directly addresses their search query
          about French e-invoicing obligations. They need to know: <em>am I affected,
          what format, and by when?</em>
        </p>
      </div>

      <!-- Flow: Country Page Entry Blocks -->
      <div class="flow-blocks">

        <!-- Block A1: Entry — Country Card (What brought them here) -->
        <div class="flow-node entry-node">
          <div class="flow-node-label">
            <span class="flow-node-num">1</span>
            <span class="flow-node-tag">Entry</span>
          </div>
          <div class="flow-node-card">
            <div class="flow-node-context">
              <span class="context-label">Why they arrived here</span>
              <p class="context-text">
                User searched "France e-invoicing mandate 2026" — they need compliance clarity
                for a specific country.
              </p>
            </div>
            <div class="flow-node-preview">
              <CountryCard
                slug={france.slug}
                name={france.name}
                isoCode={france.isoCode}
                status={france.status}
                effectiveDate={france.effectiveDate}
                mandatePhase={france.mandatePhase}
                formats={france.formats}
              />
            </div>
            <div class="flow-node-annotation">
              <span class="annotation-label">What they learn:</span>
              <span class="annotation-text">
                France is mandatory, Factur-X format, enforcement since Jan 2025.
              </span>
            </div>
          </div>
          <!-- Flow connector -->
          <div class="flow-connector">
            <svg width="24" height="32" viewBox="0 0 24 32" fill="none" aria-hidden="true">
              <path d="M12 0 L12 24 M6 18 L12 24 L18 18" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
            <span class="connector-label">Country card → Standard reference</span>
          </div>
        </div>

        <!-- Block A2: What They Learn — Standards Related to Country -->
        <div class="flow-node learning-node">
          <div class="flow-node-label">
            <span class="flow-node-num">2</span>
            <span class="flow-node-tag">Standard Reference</span>
          </div>
          <div class="flow-node-card">
            <div class="flow-node-context">
              <span class="context-label">Content they see next</span>
              <p class="context-text">
                After seeing the mandate, they want to understand the format. Related
                standards are surfaced on the country page — e.g., Factur-X for France.
              </p>
            </div>
            <div class="flow-node-preview">
              <SectionHeader
                eyebrow="Required Format"
                title={`Factur-X — France's Mandated Standard`}
                description="EN 16931-compliant hybrid format: PDF + embedded XML."
              />
              <div class="mini-card-row">
                <StandardCard
                  slug={facturx.slug}
                  name={facturx.name}
                  shortName={facturx.shortName}
                  category={facturx.category}
                  governingBody={facturx.governingBody}
                  countriesUsing={facturx.countriesUsing}
                  isPeppolBased={facturx.isPeppolBased}
                />
              </div>
            </div>
            <div class="flow-node-annotation">
              <span class="annotation-label">What they learn:</span>
              <span class="annotation-text">
                Factur-X = PDF with embedded EN 16931 XML. Hybrid = human + machine readable.
              </span>
            </div>
          </div>
          <!-- Flow connector -->
          <div class="flow-connector">
            <svg width="24" height="32" viewBox="0 0 24 32" fill="none" aria-hidden="true">
              <path d="M12 0 L12 24 M6 18 L12 24 L18 18" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
            <span class="connector-label">Format → Provider route</span>
          </div>
        </div>

        <!-- Block A3: Decision — Provider Route / Shortlist CTA -->
        <div class="flow-node decision-node">
          <div class="flow-node-label">
            <span class="flow-node-num">3</span>
            <span class="flow-node-tag">Conversion Point</span>
          </div>
          <div class="flow-node-card">
            <div class="flow-node-context">
              <span class="context-label">What they do next</span>
              <p class="context-text">
                After understanding the format, they need a provider. The provider shortlist
                CTA appears at the bottom of every country and standard page.
              </p>
            </div>
            <div class="flow-node-preview">
              <HookCard
                name="Provider Shortlist Request"
                description="Get matched with vetted e-invoicing providers for France, Factur-X, and your ERP."
                ctaLabel="Request Provider Shortlist"
                icon="shortlist"
                href="/routes"
              />
              <HookCard
                name="Country Readiness Checklist"
                description="10-point assessment for France: legal, ERP, format, timeline."
                ctaLabel="Get France Readiness Checklist"
                icon="checklist"
                href="/countries/france"
              />
            </div>
            <div class="flow-node-annotation">
              <span class="annotation-label">Next step:</span>
              <span class="annotation-text">
                Download checklist → Submit shortlist form → Evaluate providers.
              </span>
            </div>
          </div>
        </div>
      </div>

      <!-- Journey Outcome Bar -->
      <div class="journey-outcome">
        <div class="outcome-label">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
          Journey outcome
        </div>
        <p class="outcome-text">
          User confirms obligation → understands format → requests vendor shortlist.
          <strong>Conversion: Provider Shortlist Form submission.</strong>
        </p>
      </div>

    </div>
  </section>

  <!-- ============================================================ -->
  <!-- JOURNEY B: Standard Understanding Entry -->
  <!-- ============================================================ -->
  <section class="journey-section" id="journey-b" data-journey="path-b-standard-understanding">
    <div class="container-site">

      <div class="journey-header">
        <div class="journey-tag teal">
          <span class="journey-tag-dot"></span>
          Journey B
        </div>
        <div class="journey-meta">
          <div class="journey-search">
            <span class="search-icon">
              <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg>
            </span>
            <code>{journeyAnnotations['path-b-standard-understanding'].searchQuery}</code>
          </div>
          <span class="entry-page">{journeyAnnotations['path-b-standard-understanding'].entryPage}</span>
        </div>
        <h2 class="journey-title">Standard Understanding Entry</h2>
        <p class="journey-persona">Tax Manager · Compliance Manager · ERP Owner</p>
        <p class="journey-desc">
          User is trying to understand what Peppol BIS 3 is, how it relates to EN 16931,
          and which countries use it. They need conceptual clarity before operational planning.
        </p>
      </div>

      <div class="flow-blocks">

        <!-- Block B1: Entry — Standard Card -->
        <div class="flow-node entry-node">
          <div class="flow-node-label">
            <span class="flow-node-num">1</span>
            <span class="flow-node-tag">Entry</span>
          </div>
          <div class="flow-node-card">
            <div class="flow-node-context">
              <span class="context-label">Why they arrived here</span>
              <p class="context-text">
                User searched "Peppol BIS 3 explained" — they understand e-invoicing
                requires structure, but need to understand the standard landscape.
              </p>
            </div>
            <div class="flow-node-preview">
              <StandardCard
                slug={peppolBis.slug}
                name={peppolBis.name}
                shortName={peppolBis.shortName}
                category={peppolBis.category}
                governingBody={peppolBis.governingBody}
                countriesUsing={peppolBis.countriesUsing}
                isPeppolBased={peppolBis.isPeppolBased}
              />
            </div>
            <div class="flow-node-annotation">
              <span class="annotation-label">What they learn:</span>
              <span class="annotation-text">
                Peppol BIS 3 = UBL 2.1 + EN 16931 semantics + Peppol network routing.
              </span>
            </div>
          </div>
          <div class="flow-connector">
            <svg width="24" height="32" viewBox="0 0 24 32" fill="none" aria-hidden="true">
              <path d="M12 0 L12 24 M6 18 L12 24 L18 18" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
            <span class="connector-label">Standard → Country examples</span>
          </div>
        </div>

        <!-- Block B2: Country Examples — Standards Have Related Countries -->
        <div class="flow-node learning-node">
          <div class="flow-node-label">
            <span class="flow-node-num">2</span>
            <span class="flow-node-tag">Country Examples</span>
          </div>
          <div class="flow-node-card">
            <div class="flow-node-context">
              <span class="context-label">Content they see next</span>
              <p class="context-text">
                After understanding the standard, they need to know: which countries mandate
                this standard? The standard page surfaces countries using it.
              </p>
            </div>
            <div class="flow-node-preview">
              <SectionHeader
                eyebrow="Countries Using Peppol BIS 3"
                title="Where Peppol Is Mandated or Accepted"
                description={`${peppolBis.countriesUsing.length} countries across Europe and Asia-Pacific use Peppol BIS 3.`}
                size="sm"
              />
              <div class="country-grid-demo">
                {countries.filter(c => peppolBis.countriesUsing.includes(c.slug)).slice(0, 4).map(country => (
                  <CountryCard
                    slug={country.slug}
                    name={country.name}
                    isoCode={country.isoCode}
                    status={country.status}
                    effectiveDate={country.effectiveDate}
                    mandatePhase={country.mandatePhase}
                    formats={country.formats}
                    compact={true}
                  />
                ))}
              </div>
            </div>
            <div class="flow-node-annotation">
              <span class="annotation-label">What they learn:</span>
              <span class="annotation-text">
                France, Germany, Belgium, Netherlands — all mandate or accept Peppol-based formats.
              </span>
            </div>
          </div>
          <div class="flow-connector">
            <svg width="24" height="32" viewBox="0 0 24 32" fill="none" aria-hidden="true">
              <path d="M12 0 L12 24 M6 18 L12 24 L18 18" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
            <span class="connector-label">Country → Route guide</span>
          </div>
        </div>

        <!-- Block B3: Route Decision -->
        <div class="flow-node decision-node">
          <div class="flow-node-label">
            <span class="flow-node-num">3</span>
            <span class="flow-node-tag">Route Decision</span>
          </div>
          <div class="flow-node-card">
            <div class="flow-node-context">
              <span class="context-label">What they do next</span>
              <p class="context-text">
                With standard and country knowledge, they need to choose a route.
                The route page shows all four approaches with complexity indicators.
              </p>
            </div>
            <div class="flow-node-preview">
              <ProviderRouteBox route={peppolRoute} />
            </div>
            <div class="flow-node-annotation">
              <span class="annotation-label">Next step:</span>
              <span class="annotation-text">
                Select Peppol route → Check if their ERP supports it → Request shortlist.
              </span>
            </div>
          </div>
        </div>
      </div>

      <div class="journey-outcome">
        <div class="outcome-label">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
          Journey outcome
        </div>
        <p class="outcome-text">
          User understands Peppol → identifies countries → selects Peppol route → requests provider shortlist.
        </p>
      </div>

    </div>
  </section>

  <!-- ============================================================ -->
  <!-- JOURNEY C: ERP Implementation Entry -->
  <!-- ============================================================ -->
  <section class="journey-section" id="journey-c" data-journey="path-c-erp-implementation">
    <div class="container-site">

      <div class="journey-header">
        <div class="journey-tag amber">
          <span class="journey-tag-dot"></span>
          Journey C
        </div>
        <div class="journey-meta">
          <div class="journey-search">
            <span class="search-icon">
              <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg>
            </span>
            <code>{journeyAnnotations['path-c-erp-implementation'].searchQuery}</code>
          </div>
          <span class="entry-page">{journeyAnnotations['path-c-erp-implementation'].entryPage}</span>
        </div>
        <h2 class="journey-title">ERP Implementation Entry</h2>
        <p class="journey-persona">ERP Owner · Implementation Lead · Technical Architect</p>
        <p class="journey-desc">
          User manages SAP S/4HANA and needs to understand how to configure it for
          German e-invoicing. They are technically focused and need implementation specifics.
        </p>
      </div>

      <div class="flow-blocks">

        <!-- Block C1: Entry — ERP Card -->
        <div class="flow-node entry-node">
          <div class="flow-node-label">
            <span class="flow-node-num">1</span>
            <span class="flow-node-tag">Entry</span>
          </div>
          <div class="flow-node-card">
            <div class="flow-node-context">
              <span class="context-label">Why they arrived here</span>
              <p class="context-text">
                User searched "SAP e-invoicing Germany" — they manage the ERP and need
                technical configuration guidance for a specific mandate.
              </p>
            </div>
            <div class="flow-node-preview">
              <ERPCard
                slug={sap.slug}
                name={sap.name}
                vendor={sap.vendor}
                category={sap.category}
                nativeEInvoiceSupport={sap.nativeEInvoiceSupport}
                applicableCountries={sap.applicableCountries}
                configurationComplexity={sap.configurationComplexity}
              />
            </div>
            <div class="flow-node-annotation">
              <span class="annotation-label">What they learn:</span>
              <span class="annotation-text">
                SAP has native XRechnung support via output management. Complexity: High.
              </span>
            </div>
          </div>
          <div class="flow-connector">
            <svg width="24" height="32" viewBox="0 0 24 32" fill="none" aria-hidden="true">
              <path d="M12 0 L12 24 M6 18 L12 24 L18 18" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
            <span class="connector-label">ERP → Country requirements</span>
          </div>
        </div>

        <!-- Block C2: Country Requirements -->
        <div class="flow-node learning-node">
          <div class="flow-node-label">
            <span class="flow-node-num">2</span>
            <span class="flow-node-tag">Country Dossier</span>
          </div>
          <div class="flow-node-card">
            <div class="flow-node-context">
              <span class="context-label">Content they see next</span>
              <p class="context-text">
                The ERP page links to country-specific requirements. For SAP Germany,
                the ERP page surfaces German mandate details.
              </p>
            </div>
            <div class="flow-node-preview">
              <div class="country-hero mini">
                <div class="country-hero-left">
                  <div class="country-title-row">
                    <h3 class="country-title-sm">Germany</h3>
                    <StatusBadge status="mandatory" label="B2G Mandatory" />
                  </div>
                  <p class="country-phase-sm">XRechnung required for all B2G invoices</p>
                </div>
              </div>
              <InfoBlock label="Required Format" value="XRechnung (EN 16931, pure XML)" variant="compact" />
              <InfoBlock label="Enforcement Date" value="Nov 2017 (B2G)" variant="compact" />
              <InfoBlock label="Validation Tool" value="KoSIT validator" variant="compact" />
            </div>
            <div class="flow-node-annotation">
              <span class="annotation-label">What they learn:</span>
              <span class="annotation-text">
                Germany B2G mandates XRechnung. SAP configures via output management + BRF+.
              </span>
            </div>
          </div>
          <div class="flow-connector">
            <svg width="24" height="32" viewBox="0 0 24 32" fill="none" aria-hidden="true">
              <path d="M12 0 L12 24 M6 18 L12 24 L18 18" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
            <span class="connector-label">Requirements → Implementation checklist</span>
          </div>
        </div>

        <!-- Block C3: Implementation Checklist -->
        <div class="flow-node decision-node">
          <div class="flow-node-label">
            <span class="flow-node-num">3</span>
            <span class="flow-node-tag">Implementation</span>
          </div>
          <div class="flow-node-card">
            <div class="flow-node-context">
              <span class="context-label">What they do next</span>
              <p class="context-text">
                With ERP capability confirmed and country requirements clear, they need
                a structured technical implementation plan. The ERP checklist provides this.
              </p>
            </div>
            <div class="flow-node-preview">
              <ImplementationChecklist
                items={sap.implementationChecklist.slice(0, 3)}
                title={`${sap.name} Implementation Checklist`}
              />
            </div>
            <div class="flow-node-annotation">
              <span class="annotation-label">Next step:</span>
              <span class="annotation-text">
                Follow checklist steps → Test with KoSIT sandbox → Request provider shortlist for Peppol access point.
              </span>
            </div>
          </div>
        </div>
      </div>

      <div class="journey-outcome">
        <div class="outcome-label">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
          Journey outcome
        </div>
        <p class="outcome-text">
          User confirms SAP capability → understands Germany requirements → follows technical checklist → requests shortlist for access point.
        </p>
      </div>

    </div>
  </section>

  <!-- ============================================================ -->
  <!-- JOURNEY D: Route Decision Entry -->
  <!-- ============================================================ -->
  <section class="journey-section" id="journey-d" data-journey="path-d-purchase-intent">
    <div class="container-site">

      <div class="journey-header">
        <div class="journey-tag indigo">
          <span class="journey-tag-dot"></span>
          Journey D
        </div>
        <div class="journey-meta">
          <div class="journey-search">
