---
// DeadlineBanner �?EInvoiceAtlas upcoming deadline banner
export interface Props {
  country: string;
  date: string;
  phase: string;
  slug?: string;
  urgency?: 'high' | 'medium' | 'low';
}

const { country, date, phase, slug, urgency = 'high' } = Astro.props;

const isValidDate = date && !isNaN(Date.parse(date));
const formattedDate = isValidDate
  ? new Date(date).toLocaleDateString('en-GB', {
      day: 'numeric',
      month: 'long',
      year: 'numeric',
    })
  : null;
---

<div class:list={['deadline-banner', `urgency-${urgency}`]}>
  <div class="banner-icon" aria-hidden="true">
    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
      <circle cx="12" cy="12" r="10"/>
      <polyline points="12 6 12 12 16 14"/>
    </svg>
  </div>
  <div class="banner-content">
    <p class="banner-label">Upcoming Mandate �?{country}</p>
    <p class="banner-phase">{phase}</p>
    {formattedDate && <p class="banner-date">{formattedDate}</p>}
    {!formattedDate && <p class="banner-date banner-date-pending">Mandate timing under review</p>}
  </div>
  <a href={`/countries/${slug ?? country.toLowerCase().replace(/ /g, '-')}`} class="banner-cta">
    View Requirements
  </a>
</div>

<style>
  .deadline-banner {
    display: flex;
    align-items: center;
    gap: var(--space-4);
    padding: var(--space-4) var(--space-5);
    border-radius: var(--radius-xl);
    border: 1px solid;
  }

  .urgency-high {
    background: var(--color-status-critical-bg);
    border-color: rgba(153, 27, 27, 0.2);
  }

  .urgency-medium {
    background: var(--color-status-warning-bg);
    border-color: rgba(180, 83, 9, 0.2);
  }

  .urgency-low {
    background: var(--color-status-upcoming-bg);
    border-color: rgba(133, 77, 14, 0.2);
  }

  .banner-icon {
    flex-shrink: 0;
  }

  .urgency-high .banner-icon { color: var(--color-status-critical); }
  .urgency-medium .banner-icon { color: var(--color-status-warning); }
  .urgency-low .banner-icon { color: var(--color-status-upcoming); }

  .banner-content {
    flex: 1;
  }

  .banner-label {
    font-size: var(--text-xs);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: var(--tracking-wider);
    color: var(--color-slate-500);
    margin: 0 0 var(--space-1);
  }

  .banner-phase {
    font-size: var(--text-sm);
    font-weight: 600;
    color: var(--color-slate-900);
    margin: 0 0 2px;
  }

  .urgency-high .banner-phase { color: var(--color-status-critical); }
  .urgency-medium .banner-phase { color: var(--color-status-warning); }

  .banner-date {
    font-size: var(--text-sm);
    font-weight: 700;
    color: var(--color-slate-800);
    margin: 0;
  }

  .urgency-high .banner-date { color: var(--color-status-critical); }
  .urgency-medium .banner-date { color: var(--color-status-warning); }

  .banner-date-pending {
    font-style: italic;
    color: var(--color-slate-500);
    font-weight: 400;
  }

  .banner-cta {
    flex-shrink: 0;
    display: inline-flex;
    align-items: center;
    padding: var(--space-2) var(--space-4);
    font-size: var(--text-sm);
    font-weight: 600;
    background: var(--color-surface);
    border: 1px solid var(--color-border-strong);
    border-radius: var(--radius-md);
    text-decoration: none;
    color: var(--color-slate-800);
    transition: background var(--transition-fast), border-color var(--transition-fast);
  }

  .banner-cta:hover {
    background: var(--color-paper-warm);
    border-color: var(--color-slate-400);
    color: var(--color-slate-900);
  }

  .urgency-high .banner-cta {
    background: var(--color-status-critical);
    border-color: var(--color-status-critical);
    color: white;
  }

  .urgency-high .banner-cta:hover {
    background: var(--color-status-critical);
    color: white;
  }

  @media (max-width: 640px) {
    .deadline-banner {
      flex-direction: column;
      align-items: flex-start;
    }

    .banner-cta {
      align-self: stretch;
      justify-content: center;
    }
  }
</style>
