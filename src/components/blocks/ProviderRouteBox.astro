---
// ProviderRouteBox — EInvoiceAtlas route explanation block
export interface Props {
  route: {
    slug: string;
    name: string;
    shortDescription: string;
    description: string;
    howItWorks: string;
    pros: string[];
    cons: string[];
    bestFor: string[];
    complexity: string;
    costIndicators: string;
  };
}

const { route } = Astro.props;

const complexityColors: Record<string, string> = {
  low: 'complexity-low',
  medium: 'complexity-medium',
  high: 'complexity-high',
};
---

<div class="route-box">
  <div class="route-header">
    <div class="route-title-group">
      <h3 class="route-name">{route.name}</h3>
      <span class:list={['complexity-badge', complexityColors[route.complexity] ?? 'complexity-medium']}>
        {route.complexity} complexity
      </span>
    </div>
    <p class="route-short-desc">{route.shortDescription}</p>
  </div>

  <p class="route-description">{route.description}</p>

  <div class="route-details">
    <div class="route-detail-section">
      <h4 class="detail-heading">How It Works</h4>
      <div class="how-it-works">
        {route.howItWorks.split('\n').filter(l => l.trim()).map(step => (
          <p class="step">{step}</p>
        ))}
      </div>
    </div>

    <div class="route-pros-cons">
      <div class="pros-list">
        <h4 class="detail-heading">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
            <polyline points="20 6 9 17 4 12"/>
          </svg>
          Pros
        </h4>
        <ul>
          {route.pros.map(p => <li>{p}</li>)}
        </ul>
      </div>
      <div class="cons-list">
        <h4 class="detail-heading">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
            <line x1="18" y1="6" x2="6" y2="18"/>
            <line x1="6" y1="6" x2="18" y2="18"/>
          </svg>
          Considerations
        </h4>
        <ul>
          {route.cons.map(c => <li>{c}</li>)}
        </ul>
      </div>
    </div>

    <div class="route-meta">
      <div class="meta-item">
        <span class="meta-label">Best For</span>
        <span class="meta-value">{route.bestFor.join(', ')}</span>
      </div>
      <div class="meta-item">
        <span class="meta-label">Cost Indicator</span>
        <span class="meta-value">{route.costIndicators}</span>
      </div>
    </div>
  </div>
</div>

<style>
  .route-box {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-xl);
    overflow: hidden;
  }

  .route-header {
    padding: var(--space-5) var(--space-6);
    border-bottom: 1px solid var(--color-border);
  }

  .route-title-group {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    margin-bottom: var(--space-2);
  }

  .route-name {
    font-size: var(--text-lg);
    font-weight: 700;
    color: var(--color-slate-900);
    margin: 0;
  }

  .complexity-badge {
    font-size: 10px;
    font-weight: 600;
    padding: 2px 8px;
    border-radius: var(--radius-sm);
    letter-spacing: var(--tracking-wide);
    text-transform: capitalize;
  }

  .complexity-low { background: var(--color-status-active-bg); color: var(--color-status-active); }
  .complexity-medium { background: var(--color-status-upcoming-bg); color: var(--color-status-upcoming); }
  .complexity-high { background: var(--color-status-warning-bg); color: var(--color-status-warning); }

  .route-short-desc {
    font-size: var(--text-sm);
    color: var(--color-slate-600);
    margin: 0;
    font-weight: 500;
  }

  .route-description {
    font-size: var(--text-sm);
    color: var(--color-slate-700);
    line-height: var(--leading-relaxed);
    padding: var(--space-5) var(--space-6);
    margin: 0;
    border-bottom: 1px solid var(--color-border-subtle);
  }

  .route-details {
    padding: var(--space-5) var(--space-6);
    display: flex;
    flex-direction: column;
    gap: var(--space-5);
  }

  .detail-heading {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    font-size: var(--text-xs);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: var(--tracking-wider);
    color: var(--color-slate-500);
    margin: 0 0 var(--space-3);
  }

  .how-it-works {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .step {
    font-size: var(--text-sm);
    color: var(--color-slate-700);
    line-height: var(--leading-relaxed);
    margin: 0;
  }

  .route-pros-cons {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-5);
  }

  .pros-list ul,
  .cons-list ul {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .pros-list li,
  .cons-list li {
    font-size: var(--text-sm);
    color: var(--color-slate-700);
    padding-left: var(--space-4);
    position: relative;
  }

  .pros-list li::before {
    content: '+';
    position: absolute;
    left: 0;
    color: var(--color-status-active);
    font-weight: 700;
  }

  .cons-list li::before {
    content: '–';
    position: absolute;
    left: 0;
    color: var(--color-status-warning);
    font-weight: 700;
  }

  .route-meta {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    padding-top: var(--space-4);
    border-top: 1px solid var(--color-border-subtle);
  }

  .meta-item {
    display: flex;
    gap: var(--space-4);
  }

  .meta-label {
    font-size: var(--text-xs);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: var(--tracking-wider);
    color: var(--color-slate-500);
    min-width: 100px;
    flex-shrink: 0;
  }

  .meta-value {
    font-size: var(--text-sm);
    color: var(--color-slate-700);
  }

  @media (max-width: 640px) {
    .route-pros-cons {
      grid-template-columns: 1fr;
    }
  }
</style>
