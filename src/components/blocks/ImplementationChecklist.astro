---
// ImplementationChecklist — EInvoiceAtlas checklist block
export interface Props {
  items: { order: number; category: string; title: string; description: string; isCritical: boolean }[];
  title?: string;
  showCategory?: boolean;
}

const { items, title = 'Implementation Checklist', showCategory = true } = Astro.props;

const categoryLabels: Record<string, string> = {
  legal: 'Legal',
  technical: 'Technical',
  operational: 'Operational',
  financial: 'Financial',
};

const categoryColors: Record<string, string> = {
  legal: 'cat-legal',
  technical: 'cat-technical',
  operational: 'cat-operational',
  financial: 'cat-financial',
};
---

<div class="checklist-block">
  <h3 class="checklist-title">{title}</h3>
  <ol class="checklist">
    {items.map((item) => (
      <li class:list={['checklist-item', { critical: item.isCritical }]}>
        <div class="item-header">
          <span class="item-order">{String(item.order).padStart(2, '0')}</span>
          <h4 class="item-title">{item.title}</h4>
          {item.isCritical && <span class="critical-badge">Critical</span>}
          {showCategory && (
            <span class:list={['category-badge', categoryColors[item.category] ?? '']}>
              {categoryLabels[item.category] ?? item.category}
            </span>
          )}
        </div>
        <p class="item-description">{item.description}</p>
      </li>
    ))}
  </ol>
</div>

<style>
  .checklist-block {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-xl);
    padding: var(--space-6);
  }

  .checklist-title {
    font-size: var(--text-lg);
    font-weight: 700;
    color: var(--color-slate-900);
    letter-spacing: var(--tracking-tight);
    margin: 0 0 var(--space-5);
  }

  .checklist {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .checklist-item {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    padding: var(--space-4) 0;
    border-bottom: 1px solid var(--color-border-subtle);
  }

  .checklist-item:last-child {
    border-bottom: none;
    padding-bottom: 0;
  }

  .checklist-item:first-child {
    padding-top: 0;
  }

  .checklist-item.critical {
    background: var(--color-status-critical-bg);
    margin: var(--space-2) calc(-1 * var(--space-4));
    padding: var(--space-4);
    border-radius: var(--radius-lg);
    border: 1px solid rgba(153, 27, 27, 0.1);
    border-bottom: none;
  }

  .checklist-item.critical:last-child {
    border-bottom: none;
  }

  .item-header {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    flex-wrap: wrap;
  }

  .item-order {
    font-size: var(--text-xs);
    font-weight: 700;
    color: var(--color-slate-400);
    font-family: var(--font-mono);
    flex-shrink: 0;
    min-width: 24px;
  }

  .critical .item-order {
    color: var(--color-status-critical);
  }

  .item-title {
    font-size: var(--text-sm);
    font-weight: 600;
    color: var(--color-slate-900);
    margin: 0;
  }

  .critical .item-title {
    font-size: var(--text-sm);
  }

  .critical-badge {
    font-size: 10px;
    font-weight: 700;
    padding: 2px 6px;
    background: var(--color-status-critical);
    color: white;
    border-radius: var(--radius-sm);
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
  }

  .category-badge {
    font-size: 10px;
    font-weight: 600;
    padding: 2px 6px;
    border-radius: var(--radius-sm);
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
    margin-left: auto;
  }

  .cat-legal {
    background: var(--color-status-info-bg);
    color: var(--color-status-info);
  }

  .cat-technical {
    background: var(--color-status-upcoming-bg);
    color: var(--color-status-upcoming);
  }

  .cat-operational {
    background: var(--color-slate-100);
    color: var(--color-slate-600);
  }

  .cat-financial {
    background: var(--color-accent-light);
    color: var(--color-accent);
  }

  .item-description {
    font-size: var(--text-sm);
    color: var(--color-slate-600);
    line-height: var(--leading-relaxed);
    margin: 0;
    padding-left: calc(24px + var(--space-3));
  }

  .critical .item-description {
    font-size: var(--text-sm);
  }
</style>
