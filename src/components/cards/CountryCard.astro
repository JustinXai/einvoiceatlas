---
// CountryCard — EInvoiceAtlas country mandate card
import StatusBadge from '../ui/StatusBadge.astro';

export interface Props {
  slug: string;
  name: string;
  isoCode: string;
  status: string;
  effectiveDate: string | null;
  mandatePhase: string;
  formats: string[];
  compact?: boolean;
}

const { slug, name, isoCode, status, effectiveDate, mandatePhase, formats, compact = false } = Astro.props;

const statusMap: Record<string, 'active' | 'mandatory' | 'upcoming' | 'voluntary' | 'phasing'> = {
  active: 'active',
  mandatory: 'mandatory',
  upcoming: 'upcoming',
  voluntary: 'voluntary',
  phasing: 'phasing',
};

const formatLabels: Record<string, string> = {
  'factur-x': 'Factur-X',
  'ubl-2.1': 'UBL 2.1',
  'xrechnung': 'XRechnung',
  'fattura-pa': 'FatturaPA',
  'facturae': 'FacturaE',
  'simpler-invoice': 'SimplerInvoice',
};

const formatNames = formats.map((f) => formatLabels[f] ?? f).slice(0, 3);

const formattedDate = effectiveDate
  ? new Date(effectiveDate).toLocaleDateString('en-GB', { month: 'short', year: 'numeric' })
  : null;
---

<a href={`/countries/${slug}`} class:list={['country-card', { compact }]}>
  <div class="card-header">
    <div class="country-info">
      <span class="country-name">{name}</span>
      <span class="country-code">{isoCode}</span>
    </div>
    <StatusBadge status={statusMap[status] ?? 'info'} size="sm" />
  </div>

  <div class="card-body">
    {!compact && <p class="mandate-phase">{mandatePhase}</p>}

    <div class="card-meta">
      {formattedDate && (
        <div class="meta-item">
          <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <rect x="3" y="4" width="18" height="18" rx="2" ry="2"/>
            <line x1="16" y1="2" x2="16" y2="6"/>
            <line x1="8" y1="2" x2="8" y2="6"/>
            <line x1="3" y1="10" x2="21" y2="10"/>
          </svg>
          <span>{formattedDate}</span>
        </div>
      )}

      {!compact && formatNames.length > 0 && (
        <div class="format-tags">
          {formatNames.map((f) => (
            <span class="format-tag">{f}</span>
          ))}
        </div>
      )}
    </div>
  </div>

  <div class="card-arrow" aria-hidden="true">
    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
      <line x1="5" y1="12" x2="19" y2="12"/>
      <polyline points="12 5 19 12 12 19"/>
    </svg>
  </div>
</a>

<style>
  .country-card {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    padding: var(--space-5);
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-xl);
    text-decoration: none;
    transition: border-color var(--transition-fast), box-shadow var(--transition-fast), transform var(--transition-fast);
    position: relative;
  }

  .country-card:hover {
    border-color: var(--color-border-strong);
    box-shadow: var(--shadow-md);
    transform: translateY(-2px);
  }

  .compact {
    padding: var(--space-4);
    gap: var(--space-2);
  }

  .card-header {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: var(--space-3);
  }

  .country-info {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .country-name {
    font-size: var(--text-base);
    font-weight: 700;
    color: var(--color-slate-900);
    letter-spacing: var(--tracking-tight);
  }

  .compact .country-name {
    font-size: var(--text-sm);
  }

  .country-code {
    font-size: var(--text-xs);
    font-weight: 500;
    color: var(--color-slate-400);
    font-family: var(--font-mono);
  }

  .card-body {
    flex: 1;
  }

  .mandate-phase {
    font-size: var(--text-sm);
    color: var(--color-slate-600);
    line-height: var(--leading-snug);
    margin: 0 0 var(--space-3);
  }

  .card-meta {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .meta-item {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    font-size: var(--text-xs);
    color: var(--color-slate-500);
  }

  .format-tags {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-1);
  }

  .format-tag {
    font-size: 10px;
    font-weight: 500;
    padding: 2px 6px;
    background: var(--color-slate-100);
    color: var(--color-slate-600);
    border-radius: var(--radius-sm);
    letter-spacing: var(--tracking-wide);
  }

  .card-arrow {
    position: absolute;
    right: var(--space-4);
    bottom: var(--space-4);
    color: var(--color-slate-300);
    opacity: 0;
    transition: opacity var(--transition-fast), color var(--transition-fast);
  }

  .country-card:hover .card-arrow {
    opacity: 1;
    color: var(--color-accent-muted);
  }
</style>
