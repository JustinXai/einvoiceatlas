---
// HookCard — EInvoiceAtlas high-value content hook card
export interface Props {
  name: string;
  description: string;
  ctaLabel: string;
  icon: 'checklist' | 'shortlist' | 'comparison' | 'timeline' | 'route';
  href?: string;
}

const { name, description, ctaLabel, icon, href = '#' } = Astro.props;

const icons = {
  checklist: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 11l3 3L22 4"/><path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11"/></svg>`,
  shortlist: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>`,
  comparison: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="20" x2="18" y2="10"/><line x1="12" y1="20" x2="12" y2="4"/><line x1="6" y1="20" x2="6" y2="14"/></svg>`,
  timeline: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>`,
  route: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>`,
};
---

<div class="hook-card">
  <div class="hook-icon" set:html={icons[icon]} />
  <div class="hook-content">
    <h3 class="hook-name">{name}</h3>
    <p class="hook-description">{description}</p>
    <a href={href} class="hook-cta">
      {ctaLabel}
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
        <line x1="5" y1="12" x2="19" y2="12"/>
        <polyline points="12 5 19 12 12 19"/>
      </svg>
    </a>
  </div>
</div>

<style>
  .hook-card {
    display: flex;
    gap: var(--space-4);
    padding: var(--space-5) var(--space-6);
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-xl);
    transition: border-color var(--transition-fast), box-shadow var(--transition-fast);
  }

  .hook-card:hover {
    border-color: var(--color-accent-muted);
    box-shadow: var(--shadow-md);
  }

  .hook-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 44px;
    height: 44px;
    background: var(--color-accent-light);
    color: var(--color-accent);
    border-radius: var(--radius-lg);
    flex-shrink: 0;
  }

  .hook-content {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .hook-name {
    font-size: var(--text-base);
    font-weight: 700;
    color: var(--color-slate-900);
    letter-spacing: var(--tracking-tight);
    margin: 0;
  }

  .hook-description {
    font-size: var(--text-sm);
    color: var(--color-slate-600);
    line-height: var(--leading-relaxed);
    margin: 0;
  }

  .hook-cta {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    font-size: var(--text-sm);
    font-weight: 600;
    color: var(--color-accent);
    text-decoration: none;
    margin-top: var(--space-2);
    transition: gap var(--transition-fast), color var(--transition-fast);
  }

  .hook-cta:hover {
    gap: var(--space-3);
    color: var(--color-accent-hover);
  }
</style>
