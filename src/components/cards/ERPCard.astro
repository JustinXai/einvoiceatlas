---
// ERPCard — EInvoiceAtlas ERP system card
export interface Props {
  slug: string;
  name: string;
  vendor: string;
  category: string;
  nativeEInvoiceSupport: boolean;
  applicableCountries: string[];
  configurationComplexity: string;
}

const { slug, name, vendor, category, nativeEInvoiceSupport, applicableCountries, configurationComplexity } = Astro.props;

const categoryLabels: Record<string, string> = {
  enterprise: 'Enterprise',
  'mid-market': 'Mid-Market',
  smb: 'SMB',
  'open-source': 'Open Source',
};

const complexityColors: Record<string, string> = {
  low: 'complexity-low',
  medium: 'complexity-medium',
  high: 'complexity-high',
};
---

<a href={`/erp/${slug}`} class="erp-card">
  <div class="card-header">
    <span class="erp-name">{name}</span>
    <span class:list={['category-badge', `cat-${category}`]}>{categoryLabels[category] ?? category}</span>
  </div>

  <p class="vendor">{vendor}</p>

  <div class="card-meta">
    <div class="meta-item">
      <span class="meta-label">Native support</span>
      <span class:list={['meta-value', { 'support-yes': nativeEInvoiceSupport }]}>
        {nativeEInvoiceSupport ? 'Yes' : 'Add-on required'}
      </span>
    </div>
    <div class="meta-item">
      <span class="meta-label">Complexity</span>
      <span class:list={['meta-value', 'complexity', complexityColors[configurationComplexity] ?? 'complexity-medium']}>
        {configurationComplexity}
      </span>
    </div>
  </div>

  <div class="country-count">
    <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
      <circle cx="12" cy="12" r="10"/>
      <line x1="2" y1="12" x2="22" y2="12"/>
      <path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/>
    </svg>
    <span>{applicableCountries.length} countries</span>
  </div>

  <div class="card-arrow" aria-hidden="true">
    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
      <line x1="5" y1="12" x2="19" y2="12"/>
      <polyline points="12 5 19 12 12 19"/>
    </svg>
  </div>
</a>

<style>
  .erp-card {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    padding: var(--space-5);
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-xl);
    text-decoration: none;
    transition: border-color var(--transition-fast), box-shadow var(--transition-fast), transform var(--transition-fast);
    position: relative;
  }

  .erp-card:hover {
    border-color: var(--color-border-strong);
    box-shadow: var(--shadow-md);
    transform: translateY(-2px);
  }

  .card-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-3);
  }

  .erp-name {
    font-size: var(--text-base);
    font-weight: 700;
    color: var(--color-slate-900);
    letter-spacing: var(--tracking-tight);
  }

  .category-badge {
    font-size: 10px;
    font-weight: 600;
    padding: 2px 6px;
    border-radius: var(--radius-sm);
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
    background: var(--color-slate-100);
    color: var(--color-slate-600);
  }

  .vendor {
    font-size: var(--text-xs);
    color: var(--color-slate-500);
    margin: 0;
  }

  .card-meta {
    display: flex;
    gap: var(--space-4);
  }

  .meta-item {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .meta-label {
    font-size: 10px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: var(--tracking-wider);
    color: var(--color-slate-400);
  }

  .meta-value {
    font-size: var(--text-xs);
    font-weight: 500;
    color: var(--color-slate-600);
  }

  .meta-value.support-yes {
    color: var(--color-status-active);
  }

  .complexity {
    text-transform: capitalize;
  }

  .complexity-low { color: var(--color-status-active); }
  .complexity-medium { color: var(--color-status-upcoming); }
  .complexity-high { color: var(--color-status-warning); }

  .country-count {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    font-size: var(--text-xs);
    color: var(--color-slate-500);
  }

  .card-arrow {
    position: absolute;
    right: var(--space-4);
    bottom: var(--space-4);
    color: var(--color-slate-300);
    opacity: 0;
    transition: opacity var(--transition-fast), color var(--transition-fast);
  }

  .erp-card:hover .card-arrow {
    opacity: 1;
    color: var(--color-accent-muted);
  }
</style>
